# Fichiers temporaires de compilation PyInstaller
build/
*.spec

# L'exe est lourd (71 Mo) : on ne le met pas dans le dépôt.
# Il peut être distribué via une "Release" GitHub à la place.
dist/

# Cache Python
__pycache__/
*.pyc

# Données utilisateur : repères/commentaires posés sur les morceaux
commentaires.json

# Données utilisateur : carts du cartouchier (chemins locaux + touches)
carts.json

# Données utilisateur : boucles A-B enregistrées sur les morceaux
boucles.json

# Fichiers reçus depuis le téléphone (télécommande) : enregistrés au runtime
Reçus téléphone/
